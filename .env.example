# Example environment variables for local development
# Copy this file to .env.local and set real secret values. Do NOT commit your .env.local.

# The project includes a seeding script that creates a default admin user
# when you run `node scripts/seedCoreData.js`. No env vars are required
# for the seeded admin (defaults below) but you can set them if you prefer.

# Default seeded admin (change after seeding):
# Email: admin@creatinn.test
# Password: password123

# CreatINN Academy — Environment Variables
# Copy this file to .env and fill in the values.

# ─── Database ───
DATABASE_URL=file:./data/dev.db

# ─── NextAuth ───
NEXTAUTH_SECRET=change-me-to-a-random-string
NEXTAUTH_URL=http://localhost:3000

# ─── SMTP (Admin Email Notifications) ───
# When a student applies, an email is sent to ADMIN_EMAIL.
# If these are left blank the app still works — emails are just skipped.
#
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ADMIN_EMAIL=admin@creatinn.com

# ─── Paystack (Payments) ───
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
